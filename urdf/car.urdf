<?xml version="1.0"?>
<robot name="racing_car">

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.4 0.2 0.1"/></geometry>
      <material name="blue"><color rgba="0.2 0.2 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.4 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- WHEEL: front left -->
  <link name="wheel_fl">
    <visual><geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder radius="0.05" length="0.04"/></geometry></collision>
    <inertial><mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="joint_fl" type="continuous">
    <parent link="base_link"/><child link="wheel_fl"/>
    <origin xyz="0.15 0.12 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- WHEEL: front right -->
  <link name="wheel_fr">
    <visual><geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder radius="0.05" length="0.04"/></geometry></collision>
    <inertial><mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="joint_fr" type="continuous">
    <parent link="base_link"/><child link="wheel_fr"/>
    <origin xyz="0.15 -0.12 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- WHEEL: rear left -->
  <link name="wheel_rl">
    <visual><geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder radius="0.05" length="0.04"/></geometry></collision>
    <inertial><mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="joint_rl" type="continuous">
    <parent link="base_link"/><child link="wheel_rl"/>
    <origin xyz="-0.15 0.12 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- WHEEL: rear right -->
  <link name="wheel_rr">
    <visual><geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material></visual>
    <collision><geometry><cylinder radius="0.05" length="0.04"/></geometry></collision>
    <inertial><mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <joint name="joint_rr" type="continuous">
    <parent link="base_link"/><child link="wheel_rr"/>
    <origin xyz="-0.15 -0.12 -0.05" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- RAY SENSOR LINKS -->
  <link name="ray_front"/>
  <joint name="joint_ray_front" type="fixed">
    <parent link="base_link"/><child link="ray_front"/>
    <origin xyz="0.2 0.0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="ray_front_left"/>
  <joint name="joint_ray_front_left" type="fixed">
    <parent link="base_link"/><child link="ray_front_left"/>
    <origin xyz="0.2 0.0 0.05" rpy="0 0 0.5236"/>
  </joint>

  <link name="ray_front_right"/>
  <joint name="joint_ray_front_right" type="fixed">
    <parent link="base_link"/><child link="ray_front_right"/>
    <origin xyz="0.2 0.0 0.05" rpy="0 0 -0.5236"/>
  </joint>

  <link name="ray_left"/>
  <joint name="joint_ray_left" type="fixed">
    <parent link="base_link"/><child link="ray_left"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0 1.5708"/>
  </joint>

  <link name="ray_right"/>
  <joint name="joint_ray_right" type="fixed">
    <parent link="base_link"/><child link="ray_right"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0 -1.5708"/>
  </joint>

  <!-- GAZEBO: differential drive plugin -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/racing_car</namespace></ros>
      <left_joint>joint_rl</left_joint>
      <right_joint>joint_rr</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_diameter>0.1</wheel_diameter>
      <max_wheel_torque>5.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- GAZEBO: ray sensor front -->
  <gazebo reference="ray_front">
    <sensor type="ray" name="ray_sensor_front">
      <always_on>true</always_on><update_rate>20</update_rate>
      <ray><scan><horizontal>
        <samples>1</samples><resolution>1</resolution>
        <min_angle>0</min_angle><max_angle>0</max_angle>
      </horizontal></scan>
      <range><min>0.05</min><max>5.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="ray_front_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/racing_car</namespace>
          <remapping>~/out:=ray/front</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>

  <!-- GAZEBO: ray sensor front left -->
  <gazebo reference="ray_front_left">
    <sensor type="ray" name="ray_sensor_front_left">
      <always_on>true</always_on><update_rate>20</update_rate>
      <ray><scan><horizontal>
        <samples>1</samples><resolution>1</resolution>
        <min_angle>0</min_angle><max_angle>0</max_angle>
      </horizontal></scan>
      <range><min>0.05</min><max>5.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="ray_front_left_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/racing_car</namespace>
          <remapping>~/out:=ray/front_left</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>

  <!-- GAZEBO: ray sensor front right -->
  <gazebo reference="ray_front_right">
    <sensor type="ray" name="ray_sensor_front_right">
      <always_on>true</always_on><update_rate>20</update_rate>
      <ray><scan><horizontal>
        <samples>1</samples><resolution>1</resolution>
        <min_angle>0</min_angle><max_angle>0</max_angle>
      </horizontal></scan>
      <range><min>0.05</min><max>5.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="ray_front_right_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/racing_car</namespace>
          <remapping>~/out:=ray/front_right</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>

  <!-- GAZEBO: ray sensor left -->
  <gazebo reference="ray_left">
    <sensor type="ray" name="ray_sensor_left">
      <always_on>true</always_on><update_rate>20</update_rate>
      <ray><scan><horizontal>
        <samples>1</samples><resolution>1</resolution>
        <min_angle>0</min_angle><max_angle>0</max_angle>
      </horizontal></scan>
      <range><min>0.05</min><max>5.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="ray_left_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/racing_car</namespace>
          <remapping>~/out:=ray/left</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>

  <!-- GAZEBO: ray sensor right -->
  <gazebo reference="ray_right">
    <sensor type="ray" name="ray_sensor_right">
      <always_on>true</always_on><update_rate>20</update_rate>
      <ray><scan><horizontal>
        <samples>1</samples><resolution>1</resolution>
        <min_angle>0</min_angle><max_angle>0</max_angle>
      </horizontal></scan>
      <range><min>0.05</min><max>5.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="ray_right_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><namespace>/racing_car</namespace>
          <remapping>~/out:=ray/right</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>

</robot>
